{
  "name": "@aplanatic/iserv-mcp",
  "version": "0.5.17",
  "description": "Local stdio MCP server for normal-user IServ access",
  "type": "module",
  "bin": {
    "iserv-mcp": "dist/main.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/main.ts",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:live": "npm run build && node scripts/live-smoke.mjs",
    "check:sensitive": "node scripts/check-sensitive.mjs",
    "check": "npm run check:sensitive && npm run lint && npm run typecheck && npm test && npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@aplanatic/iserv-api": "^1.9.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^24.10.0",
    "tsdown": "^0.22.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "iserv",
    "mcp",
    "agents",
    "school"
  ],
  "author": "Aplanatic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aplanatic/iserv-mcp.git"
  },
  "homepage": "https://github.com/Aplanatic/iserv-mcp#readme",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  }
}
